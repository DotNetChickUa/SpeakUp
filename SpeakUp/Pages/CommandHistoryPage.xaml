<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:SpeakUp.Pages"
             xmlns:models="clr-namespace:SpeakUp.Models"
             x:Class="SpeakUp.Pages.CommandHistoryPage"
             x:DataType="pages:CommandHistoryPageViewModel"
             Title="Command History">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="20" RowSpacing="10">
        
        <!-- Header -->
        <Label Grid.Row="0"
               Text="📜 Command History"
               FontSize="24"
               FontAttributes="Bold"/>

        <!-- Statistics -->
        <Border Grid.Row="1" Padding="15">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label Text="{Binding TotalCommands}"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Total"
                           FontSize="12"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label Text="{Binding SuccessCount}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="Green"
                           HorizontalOptions="Center"/>
                    <Label Text="Success"
                           FontSize="12"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                    <Label Text="{Binding ErrorCount}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="Red"
                           HorizontalOptions="Center"/>
                    <Label Text="Errors"
                           FontSize="12"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Search and Filters -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
            <Border Grid.Column="0" Padding="5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Grid.Column="0"
                           Text="{Binding SearchText}"
                           Placeholder="Search commands..."
                           VerticalOptions="Center"
                           Margin="5,0"/>
                    <Button Grid.Column="1"
                            Text="✕"
                            Command="{Binding ClearSearchCommand}"
                            IsVisible="{Binding SearchText, Converter={StaticResource IsNotNullConverter}}"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            FontSize="16"
                            Padding="0"/>
                </Grid>
            </Border>
            
            <Button Grid.Column="1"
                    Text="🔍"
                    Command="{Binding SearchCommand}"
                    WidthRequest="50"
                    CornerRadius="8"
                    FontSize="20"
                    Padding="0"/>
            
            <Button Grid.Column="2"
                    Text="📤"
                    Command="{Binding ExportLogsCommand}"
                    WidthRequest="50"
                    CornerRadius="8"
                    FontSize="20"
                    Padding="0"/>
            
            <Button Grid.Column="3"
                    Text="🗑️"
                    Command="{Binding DeleteOldCommandsCommand}"
                    WidthRequest="50"
                    CornerRadius="8"
                    FontSize="20"
                    Padding="0"/>
        </Grid>

        <!-- Commands List -->
        <ScrollView Grid.Row="3">
            <VerticalStackLayout Spacing="10">
                
                <!-- Session Picker -->
                <Border Padding="10" IsVisible="{Binding Sessions.Count, Converter={StaticResource IsNotNullConverter}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Picker ItemsSource="{Binding Sessions}"
                            SelectedItem="{Binding SelectedSession}"
                            Title="Filter by session"
                            ItemDisplayBinding="{Binding Name}"/>
                </Border>

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                 IsVisible="{Binding IsLoading}"
                                 VerticalOptions="Center"
                                 Margin="0,20"/>

                <!-- Commands Collection -->
                <CollectionView ItemsSource="{Binding Commands}"
                              IsVisible="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CommandHistoryEntry">
                            <Border Padding="15" Margin="0,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    
                                    <!-- Header with timestamp and status -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding Timestamp, StringFormat='{0:MMM dd, yyyy HH:mm:ss}'}"
                                               FontSize="12"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Status}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                           Binding="{Binding Status}"
                                                           Value="Success">
                                                    <Setter Property="TextColor" Value="Green"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                           Binding="{Binding Status}"
                                                           Value="Error">
                                                    <Setter Property="TextColor" Value="Red"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>

                                    <BoxView HeightRequest="1" 
                                           Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"/>

                                    <!-- Command -->
                                    <Label Text="Command:"
                                           FontSize="10"
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding Command}"
                                           FontSize="14"
                                           LineBreakMode="WordWrap"/>

                                    <!-- Result -->
                                    <Label Text="Result:"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           Margin="0,5,0,0"
                                           IsVisible="{Binding Result, Converter={StaticResource IsNotNullConverter}}"/>
                                    <Label Text="{Binding Result}"
                                           FontSize="12"
                                           LineBreakMode="WordWrap"
                                           IsVisible="{Binding Result, Converter={StaticResource IsNotNullConverter}}"/>

                                    <!-- Error Message -->
                                    <Label Text="Error:"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="Red"
                                           Margin="0,5,0,0"
                                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"/>
                                    <Label Text="{Binding ErrorMessage}"
                                           FontSize="12"
                                           TextColor="Red"
                                           LineBreakMode="WordWrap"
                                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"/>

                                    <!-- Meta info -->
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                                        <Label Grid.Column="0"
                                               Text="{Binding RecognitionMode, StringFormat='Mode: {0}'}"
                                               FontSize="10"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding DurationMs, StringFormat='{0}ms'}"
                                               FontSize="10"/>
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <ContentView>
                            <VerticalStackLayout HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Padding="20">
                                <Label Text="📭"
                                       FontSize="48"
                                       HorizontalOptions="Center"/>
                                <Label Text="No commands found"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       Margin="0,10,0,0"/>
                            </VerticalStackLayout>
                        </ContentView>
                    </CollectionView.EmptyView>
                </CollectionView>
                
            </VerticalStackLayout>
        </ScrollView>

        <!-- Back Button -->
        <Button Grid.Row="4"
                Text="← Back"
                Command="{Binding NavigateBackCommand}"
                CornerRadius="8"
                Padding="15"
                Margin="0,10,0,0"/>

    </Grid>
</ContentPage>
