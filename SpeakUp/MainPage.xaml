<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:speakUp="clr-namespace:SpeakUp"
             x:Class="SpeakUp.MainPage"
             x:DataType="speakUp:MainPageViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

	<Grid Padding="20" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">
		<VerticalStackLayout Grid.Row="0"  Spacing="10" Grid.Column="0">
			<Label Text="SpeakUp Assistant"
					       FontSize="28"
					       FontAttributes="Bold"/>
			<Label Text="{Binding IsOfflineSpeechToText, Converter={StaticResource ModeConverter}}"
					       FontSize="14"/>
			<Button Text="🔄 Switch Mode"
			        Command="{Binding SwitchSpeechToTextCommand}"
			        CornerRadius="8"
			        FontAttributes="Bold"
			        FontSize="16"
			        Padding="10"/>
		</VerticalStackLayout>

		<!-- State Indicator -->
		<Border Padding="15"
                       Grid.Row="1">
			<Border.StrokeShape>
				<RoundRectangle CornerRadius="10" />
			</Border.StrokeShape>
			<VerticalStackLayout Spacing="8">
				<Label Text="Status"
                               FontSize="12"
                               FontAttributes="Bold" />
				<Label Text="{Binding State, StringFormat='State: {0}'}"
				       FontSize="16" />
				<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"/>
				<HorizontalStackLayout Spacing="10" Margin="0,5">
					<Label Text="{Binding IsListening, StringFormat='Listening: {0}'}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
				</HorizontalStackLayout>
			</VerticalStackLayout>
		</Border>

		<!-- Control Buttons -->
		<Grid ColumnDefinitions="*,*" ColumnSpacing="10" Grid.Row="2">
			<Button Grid.Column="0"
                            Text="🎤 Start"
                            Command="{Binding StartListenCommand}"
                            IsEnabled="{Binding IsStopped}"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            FontSize="16"
                            Padding="10"/>

			<Button Grid.Column="1"
                            Text="⏹ Stop"
                            Command="{Binding StopListenCommand}"
                            IsEnabled="{Binding IsStopped, Converter={StaticResource InvertBoolConverter}}"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            FontSize="16"
                            Padding="10"/>
		</Grid>

		<!-- Recognition Result -->
		<Border Grid.Row="3"
		       Padding="15"
		       IsVisible="{Binding RecognitionResult, Converter={StaticResource IsNotNullConverter}}">
			<Border.StrokeShape>
				<RoundRectangle CornerRadius="10" />
			</Border.StrokeShape>
			<VerticalStackLayout Spacing="8">
				<Label Text="Recognized Text"
				       FontSize="12"
				       FontAttributes="Bold" />
				<Label Text="{Binding RecognitionResult}"
				       FontSize="14"
				       LineBreakMode="WordWrap"/>
			</VerticalStackLayout>
		</Border>

		<!-- Logs Section -->
		<CollectionView ItemsSource="{Binding Logs}"
				Grid.Row="4">
			<CollectionView.Header>
				<Label Text="Activity Log"
                       FontSize="14"
                       FontAttributes="Bold"/>

			</CollectionView.Header>
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="x:String">
					<Border Padding="12"
                                   Margin="0,4">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="6" />
						</Border.StrokeShape>
						<Label Text="{Binding }"
							       FontSize="12"
							       LineBreakMode="WordWrap"/>

					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</Grid>

</ContentPage>

