<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:speakUp="clr-namespace:SpeakUp"
             x:Class="SpeakUp.MainPage"
             x:DataType="speakUp:MainPageViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">
	<Grid RowDefinitions="Auto,*,Auto" Padding="0">
		<!-- Header -->
		<Frame BorderColor="Transparent" 
               CornerRadius="0" 
               Padding="20" 
               Grid.Row="0">
			<VerticalStackLayout Spacing="10">
				<Label Text="SpeakUp Assistant" 
                       FontSize="28" 
                       FontAttributes="Bold"/>
				<Label Text="{Binding IsOfflineSpeechToText, StringFormat='Mode: {0:Offline|Online}'}" 
				               FontSize="14"/>
			</VerticalStackLayout>
		</Frame>

		<!-- Main Content -->
		<ScrollView Grid.Row="1">
			<VerticalStackLayout Padding="20" Spacing="20">
				<!-- State Indicator -->
				<Frame BorderColor="Transparent" 
                       CornerRadius="10" 
                       Padding="15">
					<VerticalStackLayout Spacing="8">
						<Label Text="Status" 
                               FontSize="12" 
                               FontAttributes="Bold" />
						<Label Text="{Binding State, StringFormat='State: {0}'}" 
						       FontSize="16" />
						<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"/>
						<HorizontalStackLayout Spacing="10" Margin="0,5">
							<Label Text="{Binding IsListening, StringFormat='Listening: {0}'}" 
                                   FontSize="12" 
                                   FontAttributes="Bold" 
                                   VerticalOptions="Center"/>
						</HorizontalStackLayout>
					</VerticalStackLayout>
				</Frame>

				<!-- Recognition Result -->
				<Frame BorderColor="Transparent" 
                       CornerRadius="10" 
                       Padding="15" 
                       IsVisible="{Binding RecognitionResult, Converter={StaticResource IsNotNullConverter}}">
					<VerticalStackLayout Spacing="8">
						<Label Text="Recognized Text" 
                               FontSize="12" 
                               FontAttributes="Bold" />
						<Label Text="{Binding RecognitionResult}" 
						       FontSize="14" 
						       LineBreakMode="WordWrap"/>
					</VerticalStackLayout>
				</Frame>

				<!-- Control Buttons -->
				<Grid ColumnDefinitions="*,*" ColumnSpacing="10">
					<Button Grid.Column="0"
                            Text="🎤 Start" 
                            Command="{Binding StartListenCommand}"
                            IsEnabled="{Binding IsListening, Converter={StaticResource InvertBoolConverter}}"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            FontSize="16"
                            Padding="10"/>

					<Button Grid.Column="1"
                            Text="⏹ Stop" 
                            Command="{Binding StopListenCommand}"
                            IsEnabled="{Binding IsListening}"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            FontSize="16"
                            Padding="10"/>
				</Grid>

				<Button Text="🔄 Switch Mode" 
                        Command="{Binding SwitchSpeechToTextCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontSize="16"
                        Padding="10"/>

				<!-- Logs Section -->
				<Label Text="Activity Log" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       Margin="0,10,0,0"/>

				<CollectionView ItemsSource="{Binding Logs}">
					<CollectionView.ItemTemplate>
						<DataTemplate x:DataType="x:String">
							<Frame BorderColor="Transparent" 
                                   CornerRadius="6" 
                                   Padding="12" 
                                   Margin="0,4">
								<Label Text="{Binding }" 
							       FontSize="12" 
							       LineBreakMode="WordWrap"/>

							</Frame>
						</DataTemplate>
					</CollectionView.ItemTemplate>
				</CollectionView>
			</VerticalStackLayout>
		</ScrollView>
	</Grid>
</ContentPage>

