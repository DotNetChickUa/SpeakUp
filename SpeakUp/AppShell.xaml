<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SpeakUp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SpeakUp"
    xmlns:pages="clr-namespace:SpeakUp.Pages"
    Title="SpeakUp">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Workflows"
        ContentTemplate="{DataTemplate pages:WorkflowListPage}"
        Route="WorkflowListPage" />

    <ShellContent
        Title="History"
        ContentTemplate="{DataTemplate pages:CommandHistoryPage}"
        Route="CommandHistoryPage" />

    <ShellContent
        Title="Plugins"
        ContentTemplate="{DataTemplate pages:PluginManagerPage}"
        Route="PluginManagerPage" />

    <ShellContent
        Title="Settings"
        ContentTemplate="{DataTemplate pages:SettingsPage}"
        Route="SettingsPage" />

</Shell>
